          -82.4572,27.9506,0 -82.4600,27.9600,0
        </coordinates>
      </LineString>
    </Placemark>
    <Folder>
      <name>Nested</name>
      <Placemark>
        <name>Miami Point</name>
        <Point>
          <coordinates>-80.1918,25.7617,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
  </Document>
