<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Sample KML</name>
    <Placemark>
      <name>Orlando Point</name>
      <description>Test point</description>
      <Point>
        <coordinates>-81.3792,28.5383,0</coordinates>
      </Point>
    </Placemark>
